{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist/server",
    "rootDir": ".",
    "types": ["node"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "target": "ES2020",
    "lib": ["ES2020"]
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules", "dist", "client"]
}
